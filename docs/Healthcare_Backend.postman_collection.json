{
  "info": {
    "name": "Healthcare Backend API",
    "_postman_id": "5e0f4e7d-3d21-44f7-a79a-healthcareapi",
    "description": "Postman collection for the Django DRF Healthcare Backend API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "patient_id",
      "value": "1"
    },
    {
      "key": "doctor_id",
      "value": "1"
    },
    {
      "key": "mapping_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", ""]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('access_token', json.data.access);",
                  "  pm.collectionVariables.set('refresh_token', json.data.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "token", "refresh", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Patients",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Priya Sharma\",\n  \"age\": 34,\n  \"gender\": \"female\",\n  \"phone\": \"+15550303030\",\n  \"address\": \"12 Park Avenue\",\n  \"medical_history\": \"Hypertension\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/patients/", "host": ["{{base_url}}"], "path": ["api", "patients", ""]}
          }
        },
        {
          "name": "List Patients",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/patients/?search=priya", "host": ["{{base_url}}"], "path": ["api", "patients", ""], "query": [{"key": "search", "value": "priya"}]}
          }
        },
        {
          "name": "Get Patient",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/patients/{{patient_id}}/", "host": ["{{base_url}}"], "path": ["api", "patients", "{{patient_id}}", ""]}
          }
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Priya Sharma\",\n  \"age\": 35,\n  \"gender\": \"female\",\n  \"phone\": \"+15550303030\",\n  \"address\": \"12 Park Avenue\",\n  \"medical_history\": \"Hypertension, seasonal allergies\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/patients/{{patient_id}}/", "host": ["{{base_url}}"], "path": ["api", "patients", "{{patient_id}}", ""]}
          }
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{base_url}}/api/patients/{{patient_id}}/", "host": ["{{base_url}}"], "path": ["api", "patients", "{{patient_id}}", ""]}
          }
        }
      ]
    },
    {
      "name": "Doctors",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
      },
      "item": [
        {
          "name": "Create Doctor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Dr. Aisha Mehta\",\n  \"specialization\": \"Cardiology\",\n  \"email\": \"aisha.mehta@example.com\",\n  \"phone\": \"+15550101010\",\n  \"hospital_name\": \"CityCare Hospital\",\n  \"years_of_experience\": 12\n}"
            },
            "url": {"raw": "{{base_url}}/api/doctors/", "host": ["{{base_url}}"], "path": ["api", "doctors", ""]}
          }
        },
        {
          "name": "List Doctors",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/doctors/?search=cardiology", "host": ["{{base_url}}"], "path": ["api", "doctors", ""], "query": [{"key": "search", "value": "cardiology"}]}
          }
        },
        {
          "name": "Get Doctor",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/doctors/{{doctor_id}}/", "host": ["{{base_url}}"], "path": ["api", "doctors", "{{doctor_id}}", ""]}
          }
        },
        {
          "name": "Delete Doctor",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{base_url}}/api/doctors/{{doctor_id}}/", "host": ["{{base_url}}"], "path": ["api", "doctors", "{{doctor_id}}", ""]}
          }
        }
      ]
    },
    {
      "name": "Mappings",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
      },
      "item": [
        {
          "name": "Assign Doctor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patient\": {{patient_id}},\n  \"doctor\": {{doctor_id}}\n}"
            },
            "url": {"raw": "{{base_url}}/api/mappings/", "host": ["{{base_url}}"], "path": ["api", "mappings", ""]}
          }
        },
        {
          "name": "List Mappings",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/mappings/", "host": ["{{base_url}}"], "path": ["api", "mappings", ""]}
          }
        },
        {
          "name": "Patient Assigned Doctors",
          "request": {
            "method": "GET",
            "url": {"raw": "{{base_url}}/api/mappings/{{patient_id}}/", "host": ["{{base_url}}"], "path": ["api", "mappings", "{{patient_id}}", ""]}
          }
        },
        {
          "name": "Delete Mapping",
          "request": {
            "method": "DELETE",
            "url": {"raw": "{{base_url}}/api/mappings/{{mapping_id}}/", "host": ["{{base_url}}"], "path": ["api", "mappings", "{{mapping_id}}", ""]}
          }
        }
      ]
    }
  ]
}
